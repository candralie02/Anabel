<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Obito Bergerak</title>

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      min-height: 100vh;
      background: linear-gradient(135deg, #050008, #17001f, #050008);
      display: flex;
      justify-content: center;
      align-items: center;
      overflow: hidden;
      font-family: Arial, Helvetica, sans-serif;
    }

    .stage {
      position: relative;
      width: 95vw;
      max-width: 1000px;
      aspect-ratio: 16 / 9;
      overflow: hidden;
      border-radius: 20px;
      border: 2px solid #ff4fd8;
      box-shadow:
        0 0 20px #ff4fd8,
        0 0 60px #ff00cc,
        0 0 100px rgba(255, 0, 204, 0.5);
      animation: stageFloat 4s ease-in-out infinite alternate;
      background: #000;
    }

    .foto {
      position: absolute;
      inset: 0;
      background-image: url("obito.png");
      background-size: cover;
      background-position: center;
      filter: contrast(1.15) saturate(1.2) brightness(1.08);
      animation: fotoGerak 6s ease-in-out infinite alternate;
    }

    .shake {
      position: absolute;
      inset: 0;
      animation: shakePower 2.5s ease-in-out infinite;
    }

    .aura {
      position: absolute;
      inset: -30%;
      background: conic-gradient(
        from 0deg,
        transparent,
        rgba(255, 0, 204, 0.25),
        transparent,
        rgba(120, 70, 255, 0.25),
        transparent
      );
      filter: blur(35px);
      opacity: 0.7;
      animation: auraPutar 8s linear infinite;
      z-index: 2;
      pointer-events: none;
    }

    .mata-merah,
    .mata-ungu {
      position: absolute;
      width: 22px;
      height: 22px;
      border-radius: 50%;
      z-index: 5;
      animation: mataNyala 1.2s ease-in-out infinite alternate;
      pointer-events: none;
    }

    .mata-merah {
      left: 42%;
      top: 46%;
      background: radial-gradient(circle, #fff, #ff003c 35%, transparent 72%);
      box-shadow:
        0 0 15px #ff003c,
        0 0 35px #ff003c,
        0 0 65px #ff003c;
    }

    .mata-ungu {
      left: 55%;
      top: 46%;
      background: radial-gradient(circle, #fff, #9b5cff 35%, transparent 72%);
      box-shadow:
        0 0 15px #9b5cff,
        0 0 35px #9b5cff,
        0 0 65px #9b5cff;
      animation-delay: 0.3s;
    }

    .garis {
      position: absolute;
      width: 170%;
      height: 3px;
      left: -35%;
      background: linear-gradient(90deg, transparent, #ff4fd8, #fff, #8b5cff, transparent);
      box-shadow:
        0 0 15px #ff4fd8,
        0 0 30px #8b5cff;
      opacity: 0;
      z-index: 6;
      transform: rotate(-16deg);
      animation: garisEnergi 3s linear infinite;
    }

    .garis.satu {
      top: 30%;
      animation-delay: 0s;
    }

    .garis.dua {
      top: 58%;
      animation-delay: 1s;
    }

    .garis.tiga {
      top: 75%;
      animation-delay: 2s;
    }

    .batu {
      position: absolute;
      width: 30px;
      height: 24px;
      background: linear-gradient(135deg, #75684d, #2b251c);
      clip-path: polygon(10% 0%, 80% 8%, 100% 45%, 70% 100%, 15% 85%, 0% 35%);
      filter: drop-shadow(0 0 8px rgba(255,255,255,0.3));
      z-index: 7;
      animation: batuMelayang 5s linear infinite;
    }

    .b1 { left: 10%; top: 70%; animation-delay: 0s; }
    .b2 { left: 25%; top: 35%; animation-delay: 1s; }
    .b3 { left: 50%; top: 20%; animation-delay: 2s; }
    .b4 { left: 75%; top: 65%; animation-delay: 3s; }
    .b5 { left: 90%; top: 35%; animation-delay: 4s; }

    .judul {
      position: absolute;
      left: 50%;
      bottom: 20px;
      transform: translateX(-50%);
      color: white;
      font-size: clamp(24px, 4vw, 46px);
      font-weight: 900;
      letter-spacing: 3px;
      z-index: 10;
      text-shadow:
        0 0 10px #ff4fd8,
        0 0 30px #ff00cc,
        0 0 60px #8b5cff;
      animation: judulGlow 1.5s ease-in-out infinite alternate;
    }

    .vignette {
      position: absolute;
      inset: 0;
      background:
        radial-gradient(circle at center, transparent 45%, rgba(0,0,0,0.65)),
        linear-gradient(90deg, rgba(255,0,204,0.12), transparent, rgba(139,92,255,0.12));
      z-index: 8;
      pointer-events: none;
    }

    @keyframes fotoGerak {
      0% {
        transform: scale(1) translate(0, 0);
      }
      50% {
        transform: scale(1.08) translate(-10px, -6px);
      }
      100% {
        transform: scale(1.15) translate(12px, 8px);
      }
    }

    @keyframes stageFloat {
      from {
        transform: translateY(0);
      }
      to {
        transform: translateY(-15px);
      }
    }

    @keyframes shakePower {
      0%, 100% {
        transform: translate(0, 0);
      }
      25% {
        transform: translate(1px, -1px);
      }
      50% {
        transform: translate(-1px, 1px);
      }
      75% {
        transform: translate(2px, 1px);
      }
    }

    @keyframes mataNyala {
      from {
        opacity: 0.45;
        transform: scale(0.9);
      }
      to {
        opacity: 1;
        transform: scale(1.5);
      }
    }

    @keyframes auraPutar {
      from {
        transform: rotate(0deg) scale(1.1);
      }
      to {
        transform: rotate(360deg) scale(1.1);
      }
    }

    @keyframes garisEnergi {
      0% {
        transform: translateX(-80%) rotate(-16deg);
        opacity: 0;
      }
      15% {
        opacity: 1;
      }
      30% {
        opacity: 0;
      }
      100% {
        transform: translateX(80%) rotate(-16deg);
        opacity: 0;
      }
    }

    @keyframes batuMelayang {
      0% {
        transform: translateY(120px) translateX(0) rotate(0deg) scale(0.8);
        opacity: 0;
      }
      20% {
        opacity: 1;
      }
      100% {
        transform: translateY(-180px) translateX(80px) rotate(360deg) scale(1.2);
        opacity: 0;
      }
    }

    @keyframes judulGlow {
      from {
        opacity: 0.75;
        transform: translateX(-50%) scale(1);
      }
      to {
        opacity: 1;
        transform: translateX(-50%) scale(1.05);
      }
    }

    @media (max-width: 600px) {
      .stage {
        width: 96vw;
        border-radius: 14px;
      }

      .mata-merah,
      .mata-ungu {
        width: 14px;
        height: 14px;
      }

      .judul {
        bottom: 10px;
        letter-spacing: 1px;
      }
    }
  </style>
</head>

<body>

  <div class="stage">
    <div class="aura"></div>

    <div class="shake">
      <div class="foto"></div>
    </div>

    <div class="mata-merah"></div>
    <div class="mata-ungu"></div>

    <div class="garis satu"></div>
    <div class="garis dua"></div>
    <div class="garis tiga"></div>

    <div class="batu b1"></div>
    <div class="batu b2"></div>
    <div class="batu b3"></div>
    <div class="batu b4"></div>
    <div class="batu b5"></div>

    <div class="vignette"></div>

    <div class="judul">OBITO AWAKENING</div>
  </div>

</body>
</html>
